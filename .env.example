# AI Job Search Agent — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# OpenRouter — used by CrewAI via LiteLLM (prefix models with "openrouter/")
# e.g. openrouter/anthropic/claude-3.5-sonnet, openrouter/openai/gpt-4o
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use for CrewAI agents (LiteLLM openrouter/ prefix required)
CREWAI_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Optional: LinkedIn credentials for enriched LinkedIn results (use with caution — TOS gray zone)
# LINKEDIN_EMAIL=you@example.com
# LINKEDIN_PASSWORD=your-password
